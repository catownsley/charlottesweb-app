# ========================================================================
# IMPORTANT SECURITY NOTICE
# ========================================================================
# This file shows EXAMPLE format only - it contains NO real secrets
# Copy this file to .env and fill in YOUR OWN values
# NEVER commit .env or any file with real secrets to version control
# .env is automatically ignored by git - see .gitignore
#
# For production: Use environment variables from your platform
# - Heroku: heroku config:set SECRET_KEY=...
# - AWS: Use Secrets Manager or Parameter Store
# - GCP: Use Secret Manager
# - Kubernetes: Use Secrets
# - Docker: Pass via --env flags
#
# For development: Create .env with your own values
# For extra security: Encrypt .env file:
#   python src/encryption.py encrypt .env my-master-password
# ========================================================================

# ========================================================================
# APPLICATION
# ========================================================================
APP_ENV=development
APP_NAME=CharlottesWeb
DEBUG=true

# ========================================================================
# DATABASE
# ========================================================================
# Development (SQLite): sqlite:////absolute/path/to/charlottesweb.db
# Production (PostgreSQL): postgresql://user:password@host:5432/charlottesweb
DATABASE_URL=sqlite:////absolute/path/to/your/charlottesweb-app/charlottesweb.db
RESET_DB_ON_STARTUP=false

# ========================================================================
# API
# ========================================================================
API_V1_PREFIX=/api/v1

# ========================================================================
# SECURITY - GENERATE YOUR OWN VALUES
# ========================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# DO NOT use the example value below - generate a real one
SECRET_KEY=GENERATE_YOUR_OWN_WITH_python_-c_import_secrets_print_secrets_token_urlsafe_32

# Generate API keys with: python -c "from src.security import generate_api_key; print(generate_api_key())"
# Format: comma-separated list
# Development: Can be empty or placeholder values
# Production: REQUIRED - use strong random values
VALID_API_KEYS=["your_api_key_1","your_api_key_2"]

# Require API key authentication
# Development: false (convenience)
# Production: MUST be true
API_KEY_REQUIRED=false

# JWT configuration
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========================================================================
# RATE LIMITING
# ========================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ========================================================================
# CORS (Cross-Origin Resource Sharing)
# ========================================================================
# Development: Can include localhost origins
# Production: MUST explicitly whitelist only necessary origins
# DO NOT use * in production
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:8080"]

# ========================================================================
# TLS/HTTPS (Optional for local development)
# ========================================================================
# Uncomment to enable HTTPS on localhost (requires self-signed certs)
# SSL_KEYFILE=certs/key.pem
# SSL_CERTFILE=certs/cert.pem

# ========================================================================
# EXTERNAL SERVICES (Optional)
# ========================================================================
# Anthropic API Key (optional): Required for AI-powered threat model generation
# Get from: https://console.anthropic.com/settings/keys
# Without key: /threat-model/ai endpoint returns 503
# Model can be changed: claude-sonnet-4-6 (default), claude-opus-4-6, claude-haiku-4-5
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# NVD API Key (optional): Get from https://nvd.nist.gov/developers/request-an-api-key
# Without key: 5 requests per 30 seconds
# With key: 50 requests per 30 seconds
NVD_API_KEY=
